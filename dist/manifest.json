{
  "manifest_version": 3,
  "name": "PageDrawer",
  "description": "Draw, highlight, and annotate directly on top of any website with a full-page document-aligned canvas.",
  "version": "1.0.0",
  "minimum_chrome_version": "114",
  "permissions": ["storage", "tabs", "unlimitedStorage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
